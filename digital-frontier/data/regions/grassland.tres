[gd_resource type="Resource" script_class="RegionData" load_steps=2 format=3 uid="uid://region_grassland"]

[ext_resource type="Script" path="res://resources/definitions/region_data.gd" id="1_region"]

[resource]
script = ExtResource("1_region")
id = &"grassland"
display_name = "Grassland Region"
description = "Chapter One of Digital Frontier — Pleasant Park at the heart, with Salty Springs, Fatal Fields, and Risky Reels connected by country roads, forests, and hidden trails."
