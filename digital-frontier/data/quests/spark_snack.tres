[gd_resource type="Resource" script_class="QuestData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/definitions/quest_data.gd" id="1_quest"]

[resource]
script = ExtResource("1_quest")
id = &"spark_snack"
display_name = "Spark Snack"
description = "Help your creature by collecting crystal dust on the trail."
quest_type = 1
prerequisite_quest_ids = PackedStringArray("first_steps")
reward_item_ids = PackedStringArray("hex_shard")
reward_quantities = PackedInt32Array(3)
reward_bits = 30
stages = Array[Dictionary]([{
"type": "collect",
"target_id": "crystal_dust",
"count": 1
}])
