[gd_resource type="Resource" script_class="QuestData" load_steps=2 format=3 uid="uid://quest_first_steps"]

[ext_resource type="Script" path="res://resources/definitions/quest_data.gd" id="1_quest"]

[resource]
script = ExtResource("1_quest")
id = &"first_steps"
display_name = "First Steps"
description = "Your first Field Unit outing: find the welcome sign, open a chest, and report to the Park Guide."
quest_type = 0
reward_item_ids = PackedStringArray("hex_shard", "park_map_fragment", "heal_field_salve")
reward_quantities = PackedInt32Array(2, 1, 1)
reward_bits = 50
stages = Array[Dictionary]([{
"type": "discover",
"target_id": "park_welcome",
"count": 1
}, {
"type": "chest",
"target_id": "any",
"count": 1
}, {
"type": "talk",
"target_id": "park_guide",
"count": 1
}])
start_npc_id = &"park_guide"
turn_in_npc_id = &"park_guide"
